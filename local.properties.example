## This file must *NOT* be checked into Version Control Systems,
# as it contains information specific to your local configuration.
#
# Location of the SDK. This is only used by Gradle.
# For customization when using a Version Control System, please read the
# header note.
sdk.dir=C\:\\Users\\YourUsername\\AppData\\Local\\Android\\Sdk

# API Keys - DO NOT COMMIT THIS FILE TO VERSION CONTROL
# Get your API key from https://uapis.cn/
API_KEY=your_api_key_here

# WeChat AppID - DO NOT COMMIT THIS FILE TO VERSION CONTROL
# Get your WeChat AppID from https://open.weixin.qq.com/
WECHAT_APP_ID=your_wechat_appid_here

# QQ AppID - DO NOT COMMIT THIS FILE TO VERSION CONTROL
# Get your QQ AppID from https://connect.qq.com/
QQ_APP_ID=your_qq_appid_here
