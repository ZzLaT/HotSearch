graph TD
    subgraph "View (UI 层)"
        MainActivity --> ViewPager2
        ViewPager2 --> HotSearchFragment
        ViewPager2 --> FavoriteFragment
        ViewPager2 --> SettingsFragment
        HotSearchFragment --> HotSearchAdapter
        FavoriteFragment --> HotSearchAdapter
    end

    subgraph "ViewModel (业务逻辑层)"
        HotSearchFragment --> HotSearchViewModel
        FavoriteFragment --> FavoriteViewModel
        SettingsFragment --> ThemeUtils
    end

    subgraph "Repository (数据中转层)"
        HotSearchViewModel --> HotSearchRepository
        FavoriteViewModel --> HotSearchRepository
    end

    subgraph "Model & Data (数据层)"
        HotSearchRepository --> HotSearchService["HotSearchService (Retrofit API)"]
        HotSearchRepository --> FavoriteDao["FavoriteDao (Room DB)"]
        HotSearchService --> uapis["uapis.cn (外部 API)"]
        FavoriteDao --> AppDatabase["AppDatabase (SQLite)"]
    end

    subgraph "Models (数据模型)"
        HotSearchItem
        HotSearchResponse
        Resource
    end

    HotSearchItem -.-> HotSearchService
    HotSearchItem -.-> FavoriteDao
    Resource -.-> HotSearchViewModel
